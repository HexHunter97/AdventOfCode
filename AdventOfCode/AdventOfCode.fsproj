<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <FSharpPreferNetFrameworkTools>False</FSharpPreferNetFrameworkTools>
    <RunPostBuildEvent>Always</RunPostBuildEvent>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <WarningLevel>4</WarningLevel>
    <TreatWarningsAsErrors>True</TreatWarningsAsErrors>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <WarningLevel>4</WarningLevel>

    <TreatWarningsAsErrors>True</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <None Include=".editorconfig" />
    <Content Include="Templates\DayN\example1.txt" />
    <Content Include="Templates\DayN\example2.txt" />
    <Content Include="Templates\DayN\input.txt" />
    <Content Include="Inputs\AoC2023\Day01\example1.txt" />
    <Content Include="Inputs\AoC2023\Day01\example2.txt" />
    <Content Include="Inputs\AoC2023\Day01\input.txt" />
