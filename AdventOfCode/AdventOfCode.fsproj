    <Content Include="Inputs\AoC2023\Day06\example2.txt" />
    <Content Include="Inputs\AoC2023\Day06\input.txt" />
    <Content Include="Inputs\AoC2023\Day07\example1.txt" />
    <Content Include="Inputs\AoC2023\Day07\example2.txt" />
    <Content Include="Inputs\AoC2023\Day07\input.txt" />
    <Content Include="Inputs\AoC2023\Day08\example1.txt" />
    <Content Include="Inputs\AoC2023\Day08\example2.txt" />
